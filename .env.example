# Local development (SQLite)
PAYLOAD_SECRET=change-me-to-a-long-random-string
DATABASE_URL=file:./payload.db

# Production on Vercel (set in Vercel dashboard — do not commit real values)
# PAYLOAD_SECRET=<generate with: openssl rand -hex 32>
# POSTGRES_URL=<auto-set when you link Neon Postgres>

# To regenerate Postgres migrations locally (uses postgres adapter when POSTGRES_URL is set):
# POSTGRES_URL=<copy from Vercel> pnpm run migrate:create:vercel
